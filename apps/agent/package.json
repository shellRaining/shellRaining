{
  "name": "@shellraining/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir ../.. --filter @shellraining/system-prompt build && tsx watch src/index.ts",
    "build": "tsgo -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@chat-adapter/state-memory": "^4.26.0",
    "@chat-adapter/telegram": "npm:@shellraining/chat-adapter-telegram@4.24.0",
    "@hono/node-server": "^1.14.1",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@shellraining/system-prompt": "workspace:*",
    "@sinclair/typebox": "^0.34.41",
    "chat": "^4.26.0",
    "croner": "^9.1.0",
    "dotenv": "^16.6.1",
    "hono": "^4.12.5",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.5",
    "undici": "^7.16.0"
  }
}
