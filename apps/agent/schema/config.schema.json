{
  "$id": "https://shellraining.local/schema/config.schema.json",
  "title": "shellRaining Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "number"
        }
      }
    },
    "telegram": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "botToken": {
          "type": "string"
        },
        "apiBaseUrl": {
          "type": "string"
        },
        "webhookSecret": {
          "type": "string"
        },
        "allowedUsers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "defaultAgent": {
          "type": "string"
        },
        "showThinking": {
          "type": "boolean"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseDir": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        }
      }
    },
    "agents": {
      "type": "object",
      "patternProperties": {
        "^(.*)$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "displayName": {
              "type": "string"
            },
            "piProfile": {
              "type": "string"
            },
            "aliases": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "cron": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jobsPath": {
          "type": "string"
        },
        "runTimeoutMs": {
          "type": "number"
        },
        "misfireGraceMs": {
          "type": "number"
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "anyOf": [
            {
              "const": "trace",
              "type": "string"
            },
            {
              "const": "debug",
              "type": "string"
            },
            {
              "const": "info",
              "type": "string"
            },
            {
              "const": "warn",
              "type": "string"
            },
            {
              "const": "error",
              "type": "string"
            },
            {
              "const": "fatal",
              "type": "string"
            }
          ]
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            },
            "frequency": {
              "const": "daily",
              "type": "string"
            },
            "limit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "count": {
                  "type": "number"
                },
                "removeOtherLogFiles": {
                  "type": "boolean"
                }
              }
            },
            "mkdir": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "stt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiKey": {
          "type": "string"
        },
        "baseUrl": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    }
  }
}
