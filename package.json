{
  "name": "shellRaining",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsgo -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "oxlint && oxfmt --check"
  },
  "dependencies": {
    "@chat-adapter/shared": "link:../chat-telegramify/packages/adapter-shared",
    "@chat-adapter/state-memory": "^4.24.0",
    "@chat-adapter/telegram": "link:../chat-telegramify/packages/adapter-telegram",
    "@hono/node-server": "^1.14.1",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@sinclair/typebox": "^0.34.41",
    "chat": "link:../chat-telegramify/packages/chat",
    "croner": "^9.1.0",
    "dotenv": "^16.6.1",
    "hono": "^4.12.5",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.5",
    "telegramify": "link:../chat-telegramify/packages/telegramify",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@chat-adapter/shared": "link:../chat-telegramify/packages/adapter-shared",
      "chat": "link:../chat-telegramify/packages/chat",
      "telegramify": "link:../chat-telegramify/packages/telegramify"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "koffi",
      "protobufjs"
    ]
  }
}
